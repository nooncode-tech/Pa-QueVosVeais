# ── Supabase (requerido) ──────────────────────────────────────────────────────
# Proyecto URL — visible en: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon/public key — visible en: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role key (solo servidor, NUNCA exponer al cliente)
# visible en: Supabase Dashboard > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe (opcional — para cobro con tarjeta real) ───────────────────────────
# Publishable key — visible en: Stripe Dashboard > Developers > API keys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# (para pruebas usa la clave test: pk_test_...)

# Secret key — solo servidor, NUNCA exponer al cliente
# STRIPE_SECRET_KEY=sk_live_...
# (para pruebas: sk_test_...)

# ── Next.js (opcional) ────────────────────────────────────────────────────────
# URL pública de la app en producción (para metadatos, OG, etc.)
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com
