# ── Supabase (requerido) ──────────────────────────────────────────────────────
# Proyecto URL — visible en: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon/public key — visible en: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role key (solo servidor, NUNCA exponer al cliente)
# visible en: Supabase Dashboard > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe (opcional — para cobro con tarjeta real) ───────────────────────────
# Publishable key — visible en: Stripe Dashboard > Developers > API keys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# (para pruebas usa la clave test: pk_test_...)

# Secret key — solo servidor, NUNCA exponer al cliente
# STRIPE_SECRET_KEY=sk_live_...
# (para pruebas: sk_test_...)

# ── Twilio WhatsApp (opcional — para notificaciones al cliente) ──────────────
# Account SID — visible en: Twilio Console > Dashboard
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Auth Token — visible en: Twilio Console > Dashboard
# TWILIO_AUTH_TOKEN=your_auth_token
# Número de WhatsApp de Twilio (sandbox: +14155238886 | Business: el tuyo)
# TWILIO_WHATSAPP_FROM=+14155238886

# ── Facturama CFDI (opcional — para timbrado automático ante el SAT) ─────────
# Usuario de API Facturama (Dashboard > Configuración > API)
# FACTURAMA_USER=tu_usuario
# Contraseña de API Facturama
# FACTURAMA_PASSWORD=tu_password
# Código Postal del lugar de expedición (el de tu cuenta Facturama)
# FACTURAMA_EXPEDITION_ZIP=06600
# "true" para usar el sandbox de pruebas, "false" o vacío para producción
# FACTURAMA_SANDBOX=true

# ── Next.js (opcional) ────────────────────────────────────────────────────────
# URL pública de la app en producción (para metadatos, OG, etc.)
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com
